# secrets.toml dosyasını ASLA git'e commit etme!

AZURE_ENDPOINT = "https://<resource-name>.cognitiveservices.azure.com/"
AZURE_API_KEY  = "<your-azure-api-key>"
AZURE_API_VER  = "2024-02-15-preview"
GPT_DEPLOYMENT = "gpt-4o"
